# Express Server Port
PORT=5000

# PostgreSQL Connection URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/college_management?schema=public"

# JWT Secret for backend-issued tokens
JWT_SECRET="supersecretjwtsecretforexpresstokencollegemanagement"

# Firebase Admin SDK Configuration
FIREBASE_PROJECT_ID="mock-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@mock-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMOCKKEY\n-----END PRIVATE KEY-----"

# Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME="mock_cloudinary_name"
CLOUDINARY_API_KEY="1234567890"
CLOUDINARY_API_SECRET="mock_cloudinary_secret"

# OpenAI API Key
OPENAI_API_KEY="mock-openai-key-for-local-development"
